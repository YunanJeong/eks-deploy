# ┌─────────────────────────────────────────────────────────────┐
# │ Terraform 변수값 샘플 파일                                     │
# │   1. terraform.tfvars 로 복사   2. 값 수정   3. terraform apply │
# │   실제 terraform.tfvars 는 .gitignore 로 제외됨               │
# └─────────────────────────────────────────────────────────────┘

# [필수] EKS 클러스터 이름 — default 없음. 블루/그린 시 신규 이름 지정.
cluster_name = "eks-cluster-C"

# --- 아래는 모두 선택 사항 (params.tf의 default 적용됨) ---

# 배포 리전 (기본값: ap-northeast-2)
aws_region = "ap-northeast-2"

# Kubernetes 버전 — 블루/그린 업그레이드 시 이 값을 올림 (기본값: 1.33)
cluster_version = "1.33"

# 인증 모드 (기본값: API_AND_CONFIG_MAP = Access Entry + 레거시 ConfigMap 병행)
#   레거시 앱이 없으면 "API"(Access Entry 전용)로 좁힐 수 있음
authentication_mode = "API_AND_CONFIG_MAP"

# --- 네트워크 ---
# 기존 VPC를 쓰려면 아래 3개를 채움. 비워두면 신규 VPC/서브넷을 생성함.
vpc_id             = ""
private_subnet_ids = []
public_subnet_ids  = []

# 신규 VPC 생성 시에만 사용되는 CIDR (기본값: 10.0.0.0/16)
vpc_cidr = "10.0.0.0/16"

# ⚠️ 보안 유의: 아래는 API 서버 접근을 허용할 실제 IP 대역. 사무실/VPN IP가 노출되므로 외부 공유 금지.
# 퍼블릭 엔드포인트 접근 허용 CIDR (기본값: 전체 허용 — 운영은 좁힐 것)
cluster_endpoint_public_access_cidrs = ["0.0.0.0/0"]

# --- 노드 그룹 ---
instance_types          = ["t3.medium"]
node_group_min_size     = 1
node_group_desired_size = 2
node_group_max_size     = 3

# --- 태그 (모든 리소스에 일괄 적용) ---
tags = {
  Environment = "dev"
  Terraform   = "true"
  Project     = "eks-deploy"
}
